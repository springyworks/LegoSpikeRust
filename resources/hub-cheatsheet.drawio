        <mxCell id="t5" value="hold center 2s" style="endArrow=block;endFill=1;strokeWidth=1;fontSize=8;html=1;strokeColor=#000000;curved=1;" parent="1" source="s_idle" target="s_dbg" edge="1">
          <mxGeometry relative="1" as="geometry">
