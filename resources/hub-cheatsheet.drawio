        <mxCell id="cmd_title" value="&lt;b&gt;QUICK COMMANDS&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1120" y="420" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cmd_box" value="&lt;div style=&quot;text-align:left;font-family:monospace;font-size:11px;line-height:1.8&quot;&gt;&lt;b&gt;Monitor Shell (dbg&amp;gt;):&lt;/b&gt;&lt;br&gt;&amp;nbsp; run &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;— jump to app at 0x08010000&lt;br&gt;&amp;nbsp; stop &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;— halt app, return to dbg&amp;gt;&lt;br&gt;&amp;nbsp; cont &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;— continue paused app&lt;br&gt;&amp;nbsp; regs &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;— dump CPU registers&lt;br&gt;&amp;nbsp; upload &amp;nbsp;&amp;nbsp;&amp;nbsp;— enter upload mode&lt;br&gt;&amp;nbsp; help &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;— show commands&lt;br&gt;&lt;br&gt;&lt;b&gt;Host Commands:&lt;/b&gt;&lt;br&gt;&amp;nbsp; python3 upload.py /tmp/led-test.bin /dev/ttyACM0&lt;br&gt;&amp;nbsp; picocom -b 115200 /dev/ttyACM0&lt;br&gt;&amp;nbsp; cd led-test &amp;amp;&amp;amp; cargo build --release&lt;br&gt;&amp;nbsp; arm-none-eabi-objcopy -O binary \&lt;br&gt;&amp;nbsp; &amp;nbsp; target/thumbv7em-none-eabihf/release/led-test /tmp/led-test.bin&lt;br&gt;&amp;nbsp; lsusb | grep 0694&lt;br&gt;&amp;nbsp; dfu-util -d 0694:0011 -a 0 -s 0x08010000:leave -D file.bin&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
          <mxGeometry x="1120" y="450" width="530" height="300" as="geometry" />
        </mxCell>
        <mxCell id="led_title" value="&lt;b&gt;LED RING INDICATOR&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1120" y="770" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="led_green" value="" style="ellipse;fillColor=#00cc66;strokeColor=#000000;aspect=fixed;" parent="1" vertex="1">
          <mxGeometry x="1120" y="805" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="led_green_t" value="&lt;b&gt;Green ring&lt;/b&gt; = Monitor active (dbg&amp;gt; prompt ready)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1150" y="800" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="led_blue" value="" style="ellipse;fillColor=#4488ff;strokeColor=#000000;aspect=fixed;" parent="1" vertex="1">
          <mxGeometry x="1120" y="835" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="led_blue_t" value="&lt;b&gt;Blue ring&lt;/b&gt; = App running, IDLE mode (no motors)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1150" y="830" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="led_purple" value="" style="ellipse;fillColor=#cc66ff;strokeColor=#000000;aspect=fixed;" parent="1" vertex="1">
          <mxGeometry x="1120" y="865" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="led_purple_t" value="&lt;b&gt;Purple/cycling&lt;/b&gt; = RESIDENT mode (motors + LED show)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1150" y="860" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="led_off" value="" style="ellipse;fillColor=#333333;strokeColor=#000000;aspect=fixed;" parent="1" vertex="1">
          <mxGeometry x="1120" y="895" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="led_off_t" value="&lt;b&gt;No light&lt;/b&gt; = Hub is OFF (dead / shutdown)" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1150" y="890" width="400" height="25" as="geometry" />
        </mxCell>
        <mxCell id="trouble_title" value="&lt;b&gt;TROUBLESHOOTING&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1120" y="930" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="trouble_box" value="&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.6&quot;&gt;&lt;b&gt;Serial unresponsive?&lt;/b&gt; → Hold center 2s for dbg&amp;gt;, or DFU recovery&lt;br&gt;&lt;b&gt;Empty binary (0 bytes)?&lt;/b&gt; → Build from crate dir, not workspace root!&lt;br&gt;&lt;b&gt;Port locked?&lt;/b&gt; → &lt;code&gt;fuser /dev/ttyACM0&lt;/code&gt; then &lt;code&gt;kill PID&lt;/code&gt;&lt;br&gt;&lt;b&gt;ADC hangs?&lt;/b&gt; → Monitor SysTick clears ADON. App must re-assert.&lt;br&gt;&lt;b&gt;Upload erase timeout?&lt;/b&gt; → Increase sleep in upload.py (5s)&lt;br&gt;&lt;b&gt;No /dev/ttyACM0?&lt;/b&gt; → Hub off or in DFU mode. Check &lt;code&gt;lsusb&lt;/code&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
          <mxGeometry x="1120" y="960" width="530" height="110" as="geometry" />
        </mxCell>
        <mxCell id="standalone_title" value="&lt;b&gt;STANDALONE OPERATION (No USB)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="20" y="1060" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="standalone_box" value="&lt;div style=&quot;text-align:left;font-size:11px;line-height:1.7&quot;&gt;&lt;b&gt;After full power-off (battery temp-removed, no USB):&lt;/b&gt;&lt;br&gt;1. Insert charged battery or plug USB-C&lt;br&gt;2. Press CENTER button ~1s → hub powers on → monitor starts → green ring&lt;br&gt;3. If app was previously uploaded → type &lt;code&gt;run&lt;/code&gt; (serial) OR monitor may auto-start app&lt;br&gt;4. Without serial: use button combos only (L+R=toggle, long center=shutdown)&lt;br&gt;&lt;br&gt;&lt;b&gt;App persists in flash&lt;/b&gt; — survives power loss. No re-upload needed.&lt;br&gt;&lt;b&gt;Only battery + CENTER press needed to start&lt;/b&gt; — no PC required for operation.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
          <mxGeometry y="1090" width="600" height="260" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="LegoSpikeRust Cheatsheet / 4xwMWK / A3 Landscape / Print at 100%" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=9;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="500" y="1160" width="680" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>