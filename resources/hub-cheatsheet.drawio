        </mxCell>
        <mxCell id="motor_info" value="&lt;b&gt;Motors A/B (TIM1 PWM)&lt;/b&gt;&lt;br&gt;A: PE9(ch1) / PE11(ch2) — H-bridge&lt;br&gt;B: PE13(ch3) / PE14(ch4) — H-bridge&lt;br&gt;PSC=7, ARR=999 → 12kHz&lt;br&gt;Duty +/-500 (random dir)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="608" y="560" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="status_leds" value="&lt;b&gt;Status LEDs&lt;/b&gt; (TLC5955)&lt;br&gt;Ring top/bottom: ch43/44&lt;br&gt;Battery: ch11&lt;br&gt;Bluetooth: ch12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="608" y="650" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="flash_title" value="&lt;b&gt;FLASH MEMORY MAP&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="20" y="90" width="250" height="30" as="geometry" />
        </mxCell>
        <mxCell id="flash_lego" value="&lt;b&gt;0x08000000&lt;/b&gt;  LEGO DFU Bootloader&lt;br&gt;32KB / factory / DO NOT TOUCH&lt;br&gt;USB DFU ID: 0694:0011" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="125" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="flash_mon" value="&lt;b&gt;0x08008000&lt;/b&gt;  Debug Monitor&lt;br&gt;32KB / USB CDC shell / SysTick button poll&lt;br&gt;DebugMonitor handler / upload/run/stop" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="195" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="flash_app" value="&lt;b&gt;0x08010000&lt;/b&gt;  Application (led-test)&lt;br&gt;960KB / your Rust app / ~4KB used&lt;br&gt;RandomWheel: LED animations + motor random rotations" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="265" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ram_title" value="&lt;b&gt;RAM LAYOUT&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="20" y="350" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ram_app" value="&lt;b&gt;0x20000000&lt;/b&gt;  App RAM — 312KB — .bss/.data/stack" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="20" y="380" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ram_mon" value="&lt;b&gt;0x2004E000&lt;/b&gt;  Monitor RAM (8KB)&lt;br&gt;USB/serial statics survive app exec&lt;br&gt;0x2004FFE0=DebugMon ptr / 0x2004FFE4=SysTick ptr&lt;br&gt;0x2004FFF0=DFU magic (0xDEADB007)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="20" y="420" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="table_title" value="&lt;b&gt;OPERATIONS TABLE — 4xwMWK&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="20" y="510" width="550" height="35" as="geometry" />
        </mxCell>
        <mxCell id="th_what" value="&lt;b&gt;WHAT&lt;/b&gt;&lt;br&gt;(Wat)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;fontColor=#000000;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="20" y="550" width="160" height="35" as="geometry" />
        </mxCell>
        <mxCell id="th_how" value="&lt;b&gt;HOW&lt;/b&gt;&lt;br&gt;(Hoe)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;fontColor=#000000;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="180" y="550" width="350" height="35" as="geometry" />
        </mxCell>
        <mxCell id="th_when" value="&lt;b&gt;WHEN&lt;/b&gt;&lt;br&gt;(Wanneer)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;fontColor=#000000;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="530" y="550" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="th_why" value="&lt;b&gt;WHY&lt;/b&gt;&lt;br&gt;(Waarom)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;fontColor=#000000;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="710" y="550" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="th_mwk" value="&lt;b&gt;M/W/K&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e0e0e0;fontColor=#000000;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="550" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="r1_what" value="&lt;b&gt;Power ON&lt;/b&gt;&lt;br&gt;(cold start)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="585" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_how" value="1. Plug USB-C cable&lt;br&gt;2. Press center button ~1s until ring lights green&lt;br&gt;3. Monitor boots → &lt;b&gt;green ring = dbg&amp;gt; ready&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="585" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_when" value="Hub completely dead&lt;br&gt;(no LEDs, no USB)&lt;br&gt;or after real power reset" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="585" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_why" value="PA13 must go HIGH&lt;br&gt;to latch power on.&lt;br&gt;Monitor does this in pre_init" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="585" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_mwk" value="&lt;b&gt;M&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="585" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_what" value="&lt;b&gt;Upload App&lt;/b&gt;&lt;br&gt;(flash new binary)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="640" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_how" value="&lt;b&gt;From dbg&amp;gt; prompt:&lt;/b&gt;&lt;br&gt;&lt;code&gt;python3 upload.py /tmp/led-test.bin /dev/ttyACM0&lt;/code&gt;&lt;br&gt;OR DFU: &lt;code&gt;dfu-util -d 0694:0011 -a 0 -s 0x08010000:leave -D bin&lt;/code&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="640" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_when" value="Hub at &lt;b&gt;dbg&amp;gt;&lt;/b&gt; prompt&lt;br&gt;(green ring, app stopped)&lt;br&gt;or in LEGO DFU mode" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="640" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_why" value="Writes to 0x08010000&lt;br&gt;sector 4. Erases first.&lt;br&gt;upload.py timeout=5s erase" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="640" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_mwk" value="&lt;b&gt;M&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="640" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r3_what" value="&lt;b&gt;Run App&lt;/b&gt;&lt;br&gt;(start RandomWheel)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="695" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r3_how" value="&lt;b&gt;Serial:&lt;/b&gt; type &lt;code&gt;run&lt;/code&gt; at dbg&amp;gt; prompt&lt;br&gt;&lt;b&gt;No-USB:&lt;/b&gt; power on → monitor auto-runs last uploaded app&lt;br&gt;(if app in flash at 0x08010000 with valid vector table)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="695" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r3_when" value="After upload or on&lt;br&gt;fresh power-on.&lt;br&gt;Hub at dbg&amp;gt; prompt." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="695" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r3_why" value="Jumps to 0x08010000&lt;br&gt;App takes over SysTick&lt;br&gt;via trampoline at FFE4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="695" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r3_mwk" value="&lt;b&gt;M&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="695" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r4_what" value="&lt;b&gt;Pause / Stop&lt;/b&gt;&lt;br&gt;(return to dbg&amp;gt;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="750" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r4_how" value="&lt;b&gt;Hold CENTER button ~2s&lt;/b&gt; → monitor SysTick&lt;br&gt;fires DebugMonitor → &lt;b&gt;dbg&amp;gt;&lt;/b&gt; prompt returns&lt;br&gt;Then type &lt;code&gt;stop&lt;/code&gt; to fully halt app" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="750" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r4_when" value="App is running&lt;br&gt;(blue ring, motors&lt;br&gt;moving, matrix active)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="750" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r4_why" value="SysTick stays in monitor&lt;br&gt;RAM. Polls ADC for btn.&lt;br&gt;500ms hold → DebugMon" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="750" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r4_mwk" value="&lt;b&gt;M&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="750" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r5_what" value="&lt;b&gt;Power OFF&lt;/b&gt;&lt;br&gt;(shutdown)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="805" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r5_how" value="&lt;b&gt;Long-press CENTER ~3s&lt;/b&gt; (while app running)&lt;br&gt;→ app calls shutdown_hub() → PA13 LOW → power dies&lt;br&gt;Or: &lt;b&gt;unplug USB + remove battery&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="805" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r5_when" value="Done playing.&lt;br&gt;Want to conserve battery.&lt;br&gt;Taking hub on the road." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="805" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r5_why" value="PA13 LOW drops power&lt;br&gt;latch. No drain.&lt;br&gt;Flash preserves app." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="805" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r5_mwk" value="&lt;b&gt;W&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="805" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r6_what" value="&lt;b&gt;Toggle RandomWheel&lt;/b&gt;&lt;br&gt;(LED show + motors)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="860" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r6_how" value="&lt;b&gt;Press LEFT + RIGHT simultaneously&lt;/b&gt; (~160ms window)&lt;br&gt;→ toggles resident mode on/off&lt;br&gt;Beep confirms button press (10ms @ 4kHz)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="860" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r6_when" value="App running (blue ring).&lt;br&gt;Idle mode = matrix shows&lt;br&gt;steady pattern, motors off." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="860" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r6_why" value="Both motors do random&lt;br&gt;rotations &lt;= 90 deg. xorshift32&lt;br&gt;PRNG. 0.8-2s intervals." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="860" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r6_mwk" value="&lt;b&gt;W&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="860" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r7_what" value="&lt;b&gt;DFU Recovery&lt;/b&gt;&lt;br&gt;(flash when stuck)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="915" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r7_how" value="&lt;b&gt;Hold CENTER + plug USB&lt;/b&gt; → LEGO DFU (0694:0011)&lt;br&gt;&lt;code&gt;dfu-util -d 0694:0011 -a 0 -s 0x08010000:leave -D file.bin&lt;/code&gt;&lt;br&gt;Verify: &lt;code&gt;lsusb | grep 0694&lt;/code&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="915" width="350" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r7_when" value="Hub unresponsive to&lt;br&gt;serial and center button.&lt;br&gt;Frozen/bricked app." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="915" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r7_why" value="LEGO factory BL always&lt;br&gt;intact at 0x08000000.&lt;br&gt;Last-resort recovery." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="915" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r7_mwk" value="&lt;b&gt;K&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="915" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r8_what" value="&lt;b&gt;Build App&lt;/b&gt;&lt;br&gt;(compile Rust)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="20" y="970" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r8_how" value="&lt;b&gt;!! MUST build from crate dir, NOT workspace root !!&lt;/b&gt;&lt;br&gt;&lt;code&gt;cd led-test &amp;amp;&amp;amp; cargo build --release&lt;/code&gt;&lt;br&gt;&lt;code&gt;arm-none-eabi-objcopy -O binary \&lt;br&gt;  target/thumbv7em-none-eabihf/release/led-test /tmp/led-test.bin&lt;/code&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=9;align=left;spacingLeft=5;" parent="1" vertex="1">
          <mxGeometry x="180" y="970" width="350" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r8_when" value="After code changes.&lt;br&gt;Per-crate .cargo/config&lt;br&gt;has target + link flags." style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="530" y="970" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r8_why" value="Workspace root build&lt;br&gt;ignores crate config →&lt;br&gt;&lt;b&gt;EMPTY BINARY!&lt;/b&gt;&lt;br&gt;thumbv7em-none-eabihf" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="710" y="970" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r8_mwk" value="&lt;b&gt;K&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="890" y="970" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="boot_title" value="&lt;b&gt;BOOT CHAIN (3-stage)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=none;strokeColor=none;fontSize=13;" parent="1" vertex="1">
